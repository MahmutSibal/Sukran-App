# Example environment variables for AppSukran API
# Do NOT commit real secrets. Use your CI/CD secret store or OS env vars.

# JWT signing key (use at least 32-64 random characters)
JWT_SIGNING_KEY=your-very-strong-signing-key-here

# ASP.NET environment
ASPNETCORE_ENVIRONMENT=Development

# Connection strings
ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=AppSukranDb;Trusted_Connection=True;TrustServerCertificate=True;

# Mongo settings
Mongo__ConnectionString=mongodb://localhost:27017
Mongo__DatabaseName=AppSukranDb

# Optional: Super admin seed (only for local development)
SuperAdmin__Enabled=false
SuperAdmin__Name=Super Admin
SuperAdmin__Email=superadmin@appsukran.local
SuperAdmin__Password=sukran21!
